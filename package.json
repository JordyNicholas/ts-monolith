{
  "name": "ts-monolith",
  "version": "1.0.0",
  "description": "Monolith boilerplate using TypeScript",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  },
  "scripts": {
    "prepare": "husky",
    "setup": "node scripts/setup.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run lint:architecture",
    "lint:architecture": "depcruise \"src/**/*.ts\" --config dependency-cruiser.config.mjs",
    "lint:staged": "lint-staged",
    "dev": "tsx watch src/shared/server.ts",
    "dev:worker": "tsx watch src/workers/reports.worker.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/shared/server.js",
    "start:worker": "node dist/workers/reports.worker.js",
    "test": "vitest run",
    "test:e2e": "vitest run src/shared/infra/http/app.e2e.spec.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "openapi:check": "npm run openapi:export && git diff --exit-code -- openapi/openapi.json",
    "scaffold:module": "node scripts/scaffold-module.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "tree": "npx tree-node-cli --dirs-first --exclude \"node_modules|dist|client|\\.git\""
  },
  "keywords": [],
  "author": "Jordy Nicholas",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.6",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "dependency-cruiser": "^18.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
