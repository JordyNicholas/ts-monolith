NODE_ENV=development
PORT=3333

# PostgreSQL — database name MUST match docker-compose.yml (monolith_db)
# A common local mistake is using ts_monolith here; that DB is not created by Compose.
DATABASE_URL=postgresql://user:password@localhost:5432/monolith_db

# Minimum 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Optional — defaults to JWT_SECRET + "-refresh"
# JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-at-least-32-chars

# Default tenant created by `npm run db:seed`
DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# Queue: memory (local) | bullmq (production with Redis)
QUEUE_DRIVER=memory
REDIS_URL=redis://localhost:6379

# Password hashing: argon2 (default) | bcrypt
HASH_ALGORITHM=argon2

# HTTP hardening
CORS_ORIGIN=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Observability (stub — wire OTLP exporter in production)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ts-monolith

# Enable full DB e2e tests locally (always on in CI)
# E2E_TESTS=true
