generator client {
  provider      = "prisma-client"
  // Generates the engine locally into src/shared/infra/database/client
  output        = "../client"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

// Example model to validate type generation
model User {
  id String @default(uuid())
  tenantId String
  email String @unique
  name String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([id, tenantId])

  @@unique([email, tenantId])
  @@map("users")
}